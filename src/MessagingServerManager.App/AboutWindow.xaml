<Window x:Class="MessagingServerManager.App.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Messaging Server Manager"
        Icon="Assets/AppIcon.ico"
        Width="820"
        Height="560"
        MinWidth="680"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="#07111F"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        FontSize="13">
  <Border CornerRadius="14" ClipToBounds="True" Background="#07111F">
    <Grid>
      <Image Source="Assets/Splash.png" Stretch="UniformToFill"/>
      <Rectangle Fill="#B805101F"/>
      <Grid Margin="28">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <DockPanel Margin="0,0,0,18">
          <Image DockPanel.Dock="Left" Source="Assets/AppIconTransparent.png" Width="58" Height="58" Margin="0,0,14,0"/>
          <StackPanel>
            <TextBlock Text="Messaging Server Manager" FontSize="28" FontWeight="SemiBold" Foreground="#F8FBFF"/>
            <TextBlock Text="{Binding VersionText,RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,3,0,0" Foreground="#BFD1E6"/>
          </StackPanel>
        </DockPanel>
        <Border Grid.Row="1" CornerRadius="14" Background="#EAF8FBFF" BorderBrush="#33587A" BorderThickness="1" Padding="0">
          <RichTextBox x:Name="AboutDocument"
                       IsReadOnly="True"
                       VerticalScrollBarVisibility="Auto"
                       BorderThickness="0"
                       Background="Transparent"
                       Foreground="#142033"
                       FontFamily="Segoe UI Variable Text, Segoe UI"
                       FontSize="13.5"
                       Padding="18"/>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
          <Button Content="Close" IsCancel="True" MinWidth="100" Padding="14,7" Click="Close_Click"/>
        </StackPanel>
      </Grid>
    </Grid>
  </Border>
</Window>
