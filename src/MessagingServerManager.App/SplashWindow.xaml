<Window x:Class="MessagingServerManager.App.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Messaging Server Manager"
        Icon="Assets/AppIcon.ico"
        Width="1024"
        Height="576"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ShowInTaskbar="False"
        Background="#07111F"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        FontSize="13">
  <Border CornerRadius="18" ClipToBounds="True" Background="#07111F">
    <Grid>
      <Image Source="Assets/Splash.png" Stretch="UniformToFill"/>
      <Rectangle>
        <Rectangle.Fill>
          <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#9A020916" Offset="0"/>
            <GradientStop Color="#26020916" Offset="0.35"/>
            <GradientStop Color="#15020916" Offset="0.58"/>
            <GradientStop Color="#90020916" Offset="1"/>
          </LinearGradientBrush>
        </Rectangle.Fill>
      </Rectangle>
      <StackPanel VerticalAlignment="Top" HorizontalAlignment="Left" Margin="56,38,0,0">
        <TextBlock Text="Messaging Server Manager" FontSize="34" FontWeight="SemiBold" Foreground="#F8FBFF" TextAlignment="Left">
          <TextBlock.Effect>
            <DropShadowEffect Color="#001122" BlurRadius="16" ShadowDepth="1" Opacity="0.6"/>
          </TextBlock.Effect>
        </TextBlock>
        <TextBlock Text="NATS and TIBCO RV monitoring" Margin="0,6,0,0" FontSize="15" Foreground="#C9D9EC" TextAlignment="Left"/>
      </StackPanel>
      <Grid VerticalAlignment="Bottom" Margin="56,0,56,36">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel>
          <ProgressBar Width="430" Height="3" HorizontalAlignment="Left" IsIndeterminate="True" Foreground="#2F80ED" Background="#2A3A4F" BorderThickness="0"/>
          <TextBlock Text="{Binding StatusText,RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,12,0,0" Foreground="#E2ECF8" FontSize="14"/>
        </StackPanel>
        <TextBlock Grid.Column="1" Text="{Binding VersionText,RelativeSource={RelativeSource AncestorType=Window}}" VerticalAlignment="Bottom" Foreground="#9EB5CE" FontSize="13"/>
      </Grid>
    </Grid>
  </Border>
</Window>
