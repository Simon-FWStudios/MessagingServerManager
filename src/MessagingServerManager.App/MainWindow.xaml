<Window x:Class="MessagingServerManager.App.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:local="clr-namespace:MessagingServerManager.App" Title="Messaging Server Manager" Width="1500" Height="940" MinWidth="1100" MinHeight="700" Background="#F5F7FA" FontFamily="Segoe UI" FontSize="13">
 <Window.Resources>
  <Style TargetType="Button"><Setter Property="Padding" Value="12,7"/><Setter Property="Margin" Value="3"/><Setter Property="Background" Value="White"/><Setter Property="BorderBrush" Value="#CBD5E1"/><Style.Triggers><Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.42"/></Trigger></Style.Triggers></Style>
  <Style x:Key="CompactActionButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}"><Setter Property="Width" Value="34"/><Setter Property="Height" Value="28"/><Setter Property="Padding" Value="4,2"/><Setter Property="Margin" Value="2,1"/><Setter Property="VerticalContentAlignment" Value="Center"/><Setter Property="HorizontalContentAlignment" Value="Center"/></Style>
  <Style x:Key="CenteredCellText" TargetType="TextBlock"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="TextTrimming" Value="CharacterEllipsis"/></Style>
  <Style TargetType="DataGridColumnHeader"><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Padding" Value="10"/><Setter Property="Background" Value="#F1F5F9"/></Style>
  <Style TargetType="DataGridCell"><Setter Property="Padding" Value="8,5"/><Setter Property="VerticalContentAlignment" Value="Center"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Background" Value="Transparent"/><Style.Triggers><Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#E8F3FF"/><Setter Property="Foreground" Value="#073B66"/></Trigger></Style.Triggers></Style>
  <Style TargetType="DataGridRow"><Setter Property="Background" Value="White"/><Setter Property="Foreground" Value="#111827"/><Setter Property="VerticalContentAlignment" Value="Center"/><Setter Property="BorderBrush" Value="Transparent"/><Setter Property="BorderThickness" Value="4,0,0,0"/><Style.Triggers><Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#E8F3FF"/><Setter Property="BorderBrush" Value="#1683D8"/><Setter Property="Foreground" Value="#073B66"/><Setter Property="FontWeight" Value="SemiBold"/></Trigger></Style.Triggers></Style>
 </Window.Resources>
 <DockPanel>
  <Border DockPanel.Dock="Top" Background="White" BorderBrush="#D7DEE8" BorderThickness="0,0,0,1">
   <StackPanel><TextBlock Text="Messaging Server Manager" FontSize="19" FontWeight="SemiBold" Margin="18,13,18,8"/>
    <ToolBar Background="White" Padding="10,3">
     <Button Command="{Binding StartAllCommand}" ToolTip="Start all enabled servers" AutomationProperties.Name="Start all servers"><StackPanel Orientation="Horizontal"><TextBlock Text="▶" Foreground="#16A34A" FontWeight="Bold" Margin="0,0,7,0"/><TextBlock Text="Start All"/></StackPanel></Button><Button Command="{Binding StopAllCommand}" ToolTip="Stop all running servers" AutomationProperties.Name="Stop all servers"><StackPanel Orientation="Horizontal"><TextBlock Text="■" Foreground="#DC2626" FontWeight="Bold" Margin="0,0,7,0"/><TextBlock Text="Stop All"/></StackPanel></Button><Button Command="{Binding RestartAllCommand}" ToolTip="Restart all running servers" AutomationProperties.Name="Restart all servers"><StackPanel Orientation="Horizontal"><TextBlock Text="↻" Foreground="#2563EB" FontSize="16" FontWeight="Bold" Margin="0,-2,7,-2"/><TextBlock Text="Restart All"/></StackPanel></Button><Separator/>
     <Button Command="{Binding AddServerCommand}"><StackPanel Orientation="Horizontal"><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE710;" Margin="0,0,7,0"/><TextBlock Text="Add Server"/></StackPanel></Button><Button Command="{Binding EditServerCommand}"><StackPanel Orientation="Horizontal"><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE70F;" Margin="0,0,7,0"/><TextBlock Text="Edit"/></StackPanel></Button><Button Command="{Binding DeleteServerCommand}"><StackPanel Orientation="Horizontal"><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74D;" Margin="0,0,7,0"/><TextBlock Text="Delete"/></StackPanel></Button><Separator/><Button Command="{Binding ImportConfigurationCommand}" ToolBar.OverflowMode="AsNeeded"><StackPanel Orientation="Horizontal"><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8E5;" Margin="0,0,7,0"/><TextBlock Text="Load"/></StackPanel></Button><Button Command="{Binding ExportConfigurationCommand}" ToolBar.OverflowMode="AsNeeded"><StackPanel Orientation="Horizontal"><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74E;" Margin="0,0,7,0"/><TextBlock Text="Save / Export"/></StackPanel></Button><Separator/><Button Command="{Binding RefreshCommand}" ToolBar.OverflowMode="AsNeeded"><StackPanel Orientation="Horizontal"><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE72C;" Margin="0,0,7,0"/><TextBlock Text="Refresh"/></StackPanel></Button><Button Command="{Binding OpenLogFolderCommand}" ToolBar.OverflowMode="AsNeeded"><StackPanel Orientation="Horizontal"><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8B7;" Margin="0,0,7,0"/><TextBlock Text="Open Log Folder"/></StackPanel></Button><Separator/><Button Command="{Binding SettingsCommand}" ToolBar.OverflowMode="AsNeeded"><StackPanel Orientation="Horizontal"><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" Margin="0,0,7,0"/><TextBlock Text="Settings"/></StackPanel></Button>
    </ToolBar>
   </StackPanel>
  </Border>
  <StatusBar DockPanel.Dock="Bottom" Background="White"><TextBlock Text="{Binding Servers.Count,StringFormat=Monitoring: {0} servers}"/><Separator/><Ellipse Width="10" Height="10" Fill="#22C55E" Margin="12,0,4,0"/><TextBlock Text="Monitor active"/><Separator/><TextBlock Text="{Binding LastUpdatedText}" HorizontalAlignment="Right"/></StatusBar>
  <Grid Margin="12"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
   <Border MinHeight="115" MaxHeight="330" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="4">
    <DataGrid ItemsSource="{Binding Servers}" SelectedItem="{Binding Selected}" AutoGenerateColumns="False" IsReadOnly="True" CanUserSortColumns="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal" BorderThickness="0" RowHeight="36" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
     <DataGrid.Columns>
      <DataGridTemplateColumn Header="Status" Width="70" SortMemberPath="Status"><DataGridTemplateColumn.CellTemplate><DataTemplate><StackPanel Orientation="Horizontal" VerticalAlignment="Center" ToolTip="{Binding StatusTooltip}"><Ellipse Width="16" Height="16" Fill="{Binding StatusBrush}" Margin="5,0" VerticalAlignment="Center"/></StackPanel></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
      <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="1.5*" ElementStyle="{StaticResource CenteredCellText}"/><DataGridTextColumn Header="Type" Binding="{Binding TypeText}" Width="105" ElementStyle="{StaticResource CenteredCellText}"/><DataGridTextColumn Header="Location" Binding="{Binding LocationText}" Width="80" ElementStyle="{StaticResource CenteredCellText}"/><DataGridTextColumn Header="PID" Binding="{Binding Pid}" Width="65" ElementStyle="{StaticResource CenteredCellText}"/><DataGridTemplateColumn Header="Port(s)" SortMemberPath="PrimaryPort" Width="125"><DataGridTemplateColumn.CellTemplate><DataTemplate><TextBlock Text="{Binding Ports}" ToolTip="{Binding PortsTooltip}" Style="{StaticResource CenteredCellText}"/></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn><DataGridTextColumn Header="Uptime" Binding="{Binding UptimeText}" SortMemberPath="Uptime" Width="100" ElementStyle="{StaticResource CenteredCellText}"/><DataGridTextColumn Header="CPU" Binding="{Binding CpuText}" SortMemberPath="Cpu" Width="75" ElementStyle="{StaticResource CenteredCellText}"/><DataGridTextColumn Header="Memory" Binding="{Binding MemoryText}" SortMemberPath="Memory" Width="95" ElementStyle="{StaticResource CenteredCellText}"/>
      <DataGridTemplateColumn Header="Actions" Width="160" CanUserSort="False"><DataGridTemplateColumn.CellTemplate><DataTemplate><StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Button Style="{StaticResource CompactActionButton}" ToolTip="Start server" AutomationProperties.Name="Start server" Command="{Binding DataContext.StartServerCommand,RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"><TextBlock Text="▶" Foreground="#16A34A" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/></Button><Button Style="{StaticResource CompactActionButton}" ToolTip="Stop server" AutomationProperties.Name="Stop server" Command="{Binding DataContext.StopServerCommand,RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"><TextBlock Text="■" Foreground="#DC2626" FontWeight="Bold" FontSize="14" VerticalAlignment="Center"/></Button><Button Style="{StaticResource CompactActionButton}" ToolTip="Restart server" AutomationProperties.Name="Restart server" Command="{Binding DataContext.RestartServerCommand,RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"><TextBlock Text="↻" Foreground="#2563EB" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/></Button><Button Style="{StaticResource CompactActionButton}" ToolTip="{Binding RowActionTooltip}" AutomationProperties.Name="{Binding RowActionTooltip}" Command="{Binding DataContext.InspectServerCommand,RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"><TextBlock FontFamily="Segoe MDL2 Assets" Text="{Binding RowActionGlyph}" Foreground="#D97706" FontWeight="Bold" FontSize="15" VerticalAlignment="Center"/></Button></StackPanel></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
     </DataGrid.Columns>
    </DataGrid>
   </Border>
   <Border Grid.Row="1" Margin="0,8" Padding="14" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="4">
    <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
     <StackPanel Margin="0,0,18,0"><TextBlock Text="{Binding Selected.Name,StringFormat=Server Details — {0}}" Foreground="#075DB3" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,8"/><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="115"/><ColumnDefinition/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions><TextBlock Text="Executable / URL" FontWeight="SemiBold"/><TextBlock Grid.Column="1" Text="{Binding Selected.ExecutableDisplay}" ToolTip="{Binding Selected.ExecutableDisplay}" TextTrimming="CharacterEllipsis"/><TextBlock Grid.Row="1" Text="Working directory" FontWeight="SemiBold"/><TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Selected.Definition.WorkingDirectory}" ToolTip="{Binding Selected.Definition.WorkingDirectory}" TextTrimming="CharacterEllipsis"/><TextBlock Grid.Row="2" Text="Launch mode" FontWeight="SemiBold"/><TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Selected.Definition.LaunchMode}"/><TextBlock Grid.Row="3" Text="Config file" FontWeight="SemiBold"/><TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Selected.Definition.ConfigFilePath}" ToolTip="{Binding Selected.Definition.ConfigFilePath}" TextTrimming="CharacterEllipsis"/><TextBlock Grid.Row="4" Text="Arguments" FontWeight="SemiBold"/><TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Selected.Definition.AdditionalArguments}" ToolTip="{Binding Selected.Definition.AdditionalArguments}" TextTrimming="CharacterEllipsis"/></Grid></StackPanel>
     <StackPanel Grid.Column="1"><TextBlock Text="Process Statistics" FontWeight="SemiBold" Margin="0,0,0,8"/><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="75"/><ColumnDefinition/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions><TextBlock Text="Status" FontWeight="SemiBold"/><TextBlock Grid.Column="1" Text="{Binding Selected.StatusText}"/><TextBlock Grid.Row="1" Text="PID" FontWeight="SemiBold"/><TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Selected.Pid}"/><TextBlock Grid.Row="2" Text="Uptime" FontWeight="SemiBold"/><TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Selected.UptimeText}"/><TextBlock Grid.Row="3" Text="CPU" FontWeight="SemiBold"/><TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Selected.CpuText}"/><TextBlock Grid.Row="4" Text="Memory" FontWeight="SemiBold"/><TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Selected.MemoryText}"/></Grid></StackPanel>
     <StackPanel Grid.Column="2"><TextBlock Text="Health and Exit" FontWeight="SemiBold" Margin="0,0,0,8"/><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="95"/><ColumnDefinition/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions><TextBlock Text="Health" FontWeight="SemiBold"/><TextBlock Grid.Column="1" Text="{Binding Selected.Health}" TextWrapping="Wrap"/><TextBlock Grid.Row="1" Text="Last exit code" FontWeight="SemiBold"/><TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Selected.LastExitCode}"/><TextBlock Grid.Row="2" Text="Last error" FontWeight="SemiBold"/><TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Selected.LastError}" Foreground="#B91C1C" TextWrapping="Wrap"/></Grid><StackPanel Orientation="Horizontal" Margin="0,10,0,0"><Button Style="{StaticResource CompactActionButton}" Command="{Binding OpenLogCommand}" ToolTip="Open log file" AutomationProperties.Name="Open log file"><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A5;" Foreground="#D97706" FontSize="16" VerticalAlignment="Center"/></Button><Button Style="{StaticResource CompactActionButton}" Command="{Binding OpenLogFolderCommand}" ToolTip="Open log folder" AutomationProperties.Name="Open log folder"><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8B7;" Foreground="#D97706" FontSize="16" VerticalAlignment="Center"/></Button></StackPanel></StackPanel>
    </Grid>
   </Border>
   <TabControl Grid.Row="2" Background="White" SelectedIndex="{Binding SelectedDetailTabIndex}"><TabItem Header="Live Log"><DockPanel><StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,2,3,2"><Button Style="{StaticResource CompactActionButton}" Command="{Binding PauseLogCommand}" ToolTip="Pause live log" AutomationProperties.Name="Pause live log"><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE769;" Foreground="#2563EB" FontSize="15"/></Button><Button Style="{StaticResource CompactActionButton}" Command="{Binding ResumeLogCommand}" ToolTip="Resume live log" AutomationProperties.Name="Resume live log"><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE768;" Foreground="#16A34A" FontSize="15"/></Button><Button Style="{StaticResource CompactActionButton}" Command="{Binding ClearLogCommand}" ToolTip="Clear log view" AutomationProperties.Name="Clear log view"><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74D;" Foreground="#DC2626" FontSize="15"/></Button></StackPanel><RichTextBox local:RichTextBoxLogBehavior.Text="{Binding LogText}" IsReadOnly="True" IsReadOnlyCaretVisible="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12.5" Background="#111827" Foreground="#E5E7EB" Padding="10" BorderThickness="0"/></DockPanel></TabItem><TabItem Header="Server Metrics"><DockPanel><StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,2,3,2"><Button Style="{StaticResource CompactActionButton}" Command="{Binding RefreshSelectedTelemetryCommand}" ToolTip="Refresh telemetry" AutomationProperties.Name="Refresh telemetry"><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE72C;" Foreground="#2563EB" FontSize="15"/></Button><Button Style="{StaticResource CompactActionButton}" Command="{Binding CopyRawTelemetryCommand}" ToolTip="Copy raw telemetry" AutomationProperties.Name="Copy raw telemetry"><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8C8;" Foreground="#475569" FontSize="15"/></Button><Button Style="{StaticResource CompactActionButton}" Command="{Binding OpenRawTelemetryCommand}" ToolTip="Open telemetry endpoint" AutomationProperties.Name="Open telemetry endpoint"><TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8A7;" Foreground="#D97706" FontSize="15"/></Button></StackPanel><TabControl><TabItem Header="Summary"><TextBox Margin="10" Text="{Binding SelectedRemoteMetrics,Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="13" Padding="8"/></TabItem><TabItem Header="Raw"><TextBox Margin="10" Text="{Binding SelectedRawTelemetry,Mode=OneWay}" IsReadOnly="True" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12" Padding="8"/></TabItem></TabControl></DockPanel></TabItem><TabItem Header="Process Details"><Grid Margin="15"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="{Binding Selected.Started,StringFormat=Started: {0:G}}"/><TextBlock Text="{Binding Selected.LastChecked,StringFormat=Last checked: {0:G}}"/><TextBlock Text="{Binding Selected.LastExitTime,StringFormat=Last exit: {0:G}}"/><TextBlock Text="{Binding Selected.LastExitCode,StringFormat=Exit code: {0}}"/><TextBlock Text="{Binding Selected.RestartCount,StringFormat=Restart count: {0}}"/></StackPanel><StackPanel Grid.Column="1"><TextBlock Text="Effective arguments or monitoring endpoint" FontWeight="SemiBold"/><TextBox Text="{Binding SelectedEffectiveArguments,Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" Margin="0,6" Padding="6"/></StackPanel></Grid></TabItem><TabItem Header="Configuration Summary"><TextBox Margin="15" Text="{Binding SelectedConfigurationSummary,Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" FontFamily="Consolas"/></TabItem></TabControl>
  </Grid>
 </DockPanel>
</Window>
