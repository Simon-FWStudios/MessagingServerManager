<Window x:Class="MessagingServerManager.App.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Messaging Server Manager" Width="1500" Height="940" MinWidth="1100" MinHeight="700" Background="#F5F7FA" FontFamily="Segoe UI" FontSize="13">
 <Window.Resources>
  <Style TargetType="Button"><Setter Property="Padding" Value="12,7"/><Setter Property="Margin" Value="3"/><Setter Property="Background" Value="White"/><Setter Property="BorderBrush" Value="#CBD5E1"/></Style>
  <Style TargetType="DataGridColumnHeader"><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Padding" Value="10"/><Setter Property="Background" Value="#F1F5F9"/></Style>
  <Style TargetType="DataGridCell"><Setter Property="Padding" Value="8,5"/><Setter Property="VerticalContentAlignment" Value="Center"/></Style>
 </Window.Resources>
 <DockPanel>
  <Border DockPanel.Dock="Top" Background="White" BorderBrush="#D7DEE8" BorderThickness="0,0,0,1">
   <StackPanel><TextBlock Text="Messaging Server Manager" FontSize="19" FontWeight="SemiBold" Margin="18,13,18,8"/>
    <ToolBar Background="White" Padding="10,3">
     <Button Command="{Binding StartAllCommand}" Content="▶  Start All"/><Button Command="{Binding StopAllCommand}" Content="■  Stop All"/><Button Command="{Binding RestartAllCommand}" Content="↻  Restart All"/><Separator/>
     <Button Command="{Binding AddServerCommand}" Content="＋  Add Server"/><Button Command="{Binding EditServerCommand}" Content="✎  Edit"/><Button Command="{Binding DeleteServerCommand}" Content="⌫  Delete"/><Separator/><Button Command="{Binding ImportConfigurationCommand}" Content="📂  Load"/><Button Command="{Binding ExportConfigurationCommand}" Content="💾  Save / Export"/><Separator/><Button Command="{Binding RefreshCommand}" Content="↻  Refresh"/><Button Command="{Binding OpenLogFolderCommand}" Content="📁  Open Log Folder"/><Separator/><Button Command="{Binding SettingsCommand}" Content="⚙  Settings"/>
    </ToolBar>
   </StackPanel>
  </Border>
  <StatusBar DockPanel.Dock="Bottom" Background="White"><TextBlock Text="{Binding Servers.Count,StringFormat=Monitoring: {0} servers}"/><Separator/><Ellipse Width="10" Height="10" Fill="#22C55E" Margin="12,0,4,0"/><TextBlock Text="Monitor active"/><Separator/><TextBlock Text="{Binding LastUpdatedText}" HorizontalAlignment="Right"/></StatusBar>
  <Grid Margin="12"><Grid.RowDefinitions><RowDefinition Height="2.1*"/><RowDefinition Height="1.1*"/><RowDefinition Height="2*"/></Grid.RowDefinitions>
   <Border Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="4">
    <DataGrid ItemsSource="{Binding Servers}" SelectedItem="{Binding Selected}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal" BorderThickness="0">
     <DataGrid.Columns>
      <DataGridTemplateColumn Header="Status" Width="70"><DataGridTemplateColumn.CellTemplate><DataTemplate><StackPanel Orientation="Horizontal" ToolTip="{Binding Health}"><Ellipse Width="16" Height="16" Fill="{Binding StatusBrush}" Margin="5"/></StackPanel></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
      <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="1.4*"/><DataGridTextColumn Header="Type" Binding="{Binding TypeText}" Width="100"/><DataGridTextColumn Header="PID" Binding="{Binding Pid}" Width="70"/><DataGridTextColumn Header="Port(s)" Binding="{Binding Ports}" Width="120"/><DataGridTextColumn Header="Uptime" Binding="{Binding UptimeText}" Width="105"/><DataGridTextColumn Header="CPU" Binding="{Binding CpuText}" Width="70"/><DataGridTextColumn Header="Memory" Binding="{Binding MemoryText}" Width="90"/><DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="100"/><DataGridTextColumn Header="Log File" Binding="{Binding LogFile}" Width="1.5*"/>
      <DataGridTemplateColumn Header="Actions" Width="260"><DataGridTemplateColumn.CellTemplate><DataTemplate><StackPanel Orientation="Horizontal"><Button Content="Start" Command="{Binding DataContext.StartServerCommand,RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/><Button Content="Stop" Command="{Binding DataContext.StopServerCommand,RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/><Button Content="Restart" Command="{Binding DataContext.RestartServerCommand,RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/><Button Content="Log" Command="{Binding DataContext.OpenServerLogCommand,RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/></StackPanel></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
     </DataGrid.Columns>
    </DataGrid>
   </Border>
   <Border Grid.Row="1" Margin="0,8" Padding="14" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="4">
    <Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
     <StackPanel><TextBlock Text="{Binding Selected.Name,StringFormat=Server Details — {0}}" Foreground="#075DB3" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,8"/><TextBlock Text="{Binding Selected.Definition.Executable,StringFormat=Executable: {0}}"/><TextBlock Text="{Binding Selected.Definition.WorkingDirectory,StringFormat=Working directory: {0}}"/><TextBlock Text="{Binding Selected.Definition.LaunchMode,StringFormat=Launch mode: {0}}"/><TextBlock Text="{Binding Selected.Definition.ConfigFilePath,StringFormat=Config file: {0}}"/><TextBlock Text="{Binding Selected.Definition.AdditionalArguments,StringFormat=Arguments: {0}}" TextWrapping="Wrap"/></StackPanel>
     <StackPanel Grid.Column="1"><TextBlock Text="Process Statistics" FontWeight="SemiBold" Margin="0,0,0,8"/><TextBlock Text="{Binding Selected.StatusText,StringFormat=Status: {0}}"/><TextBlock Text="{Binding Selected.Pid,StringFormat=PID: {0}}"/><TextBlock Text="{Binding Selected.UptimeText,StringFormat=Uptime: {0}}"/><TextBlock Text="{Binding Selected.CpuText,StringFormat=CPU: {0}}"/><TextBlock Text="{Binding Selected.MemoryText,StringFormat=Memory: {0}}"/></StackPanel>
     <StackPanel Grid.Column="2"><TextBlock Text="Health and Exit" FontWeight="SemiBold" Margin="0,0,0,8"/><TextBlock Text="{Binding Selected.Health,StringFormat=Health: {0}}" TextWrapping="Wrap"/><TextBlock Text="{Binding Selected.LastExitCode,StringFormat=Last exit code: {0}}"/><TextBlock Text="{Binding Selected.LastError,StringFormat=Last error: {0}}" Foreground="#B91C1C" TextWrapping="Wrap"/><StackPanel Orientation="Horizontal" Margin="0,10,0,0"><Button Command="{Binding OpenLogCommand}" Content="Open Log"/><Button Command="{Binding OpenLogFolderCommand}" Content="Open Folder"/></StackPanel></StackPanel>
    </Grid>
   </Border>
   <TabControl Grid.Row="2" Background="White"><TabItem Header="Live Log"><DockPanel><StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Right"><Button Command="{Binding PauseLogCommand}" Content="Pause"/><Button Command="{Binding ResumeLogCommand}" Content="Resume"/><Button Command="{Binding ClearLogCommand}" Content="Clear"/></StackPanel><TextBox Text="{Binding LogText}" IsReadOnly="True" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12.5" Background="#111827" Foreground="#E5E7EB" Padding="10"/></DockPanel></TabItem><TabItem Header="Process Details"><Grid Margin="15"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="{Binding Selected.Started,StringFormat=Started: {0:G}}"/><TextBlock Text="{Binding Selected.LastChecked,StringFormat=Last checked: {0:G}}"/><TextBlock Text="{Binding Selected.LastExitTime,StringFormat=Last exit: {0:G}}"/><TextBlock Text="{Binding Selected.LastExitCode,StringFormat=Exit code: {0}}"/><TextBlock Text="{Binding Selected.RestartCount,StringFormat=Restart count: {0}}"/></StackPanel><StackPanel Grid.Column="1"><TextBlock Text="Effective arguments" FontWeight="SemiBold"/><TextBox Text="{Binding SelectedEffectiveArguments,Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" Margin="0,6" Padding="6"/></StackPanel></Grid></TabItem><TabItem Header="Configuration Summary"><TextBox Margin="15" Text="{Binding SelectedConfigurationSummary,Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" FontFamily="Consolas"/></TabItem></TabControl>
  </Grid>
 </DockPanel>
</Window>
