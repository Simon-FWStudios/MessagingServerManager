<?xml version="1.0"?>
<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:local="clr-namespace:MessagingServerManager.App" xmlns:icons="clr-namespace:FluentIcons.Wpf;assembly=FluentIcons.Wpf" x:Class="MessagingServerManager.App.MainWindow" Title="Messaging Server Manager" Width="1650" Height="940" MinWidth="1100" MinHeight="700" Background="#F4F6F9" FontFamily="Segoe UI Variable Text, Segoe UI" FontSize="13">
  <Window.Resources>
    <Style TargetType="Button">
      <Setter Property="Padding" Value="11,7"/>
      <Setter Property="Margin" Value="2"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="#263246"/>
      <Setter Property="BorderBrush" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#EEF3F9"/>
          <Setter Property="BorderBrush" Value="#D7E0EB"/>
        </Trigger>
        <Trigger Property="IsEnabled" Value="False">
          <Setter Property="Opacity" Value="0.35"/>
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Background" Value="#1261A6"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderBrush" Value="#1261A6"/>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#0D4F8C"/>
          <Setter Property="BorderBrush" Value="#0D4F8C"/>
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="CompactActionButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Width" Value="34"/>
      <Setter Property="Height" Value="28"/>
      <Setter Property="Padding" Value="4,2"/>
      <Setter Property="Margin" Value="2,1"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>
    <Style x:Key="IconButton" TargetType="Button" BasedOn="{StaticResource CompactActionButton}">
      <Setter Property="Width" Value="36"/>
      <Setter Property="Height" Value="34"/>
    </Style>
    <Style x:Key="Card" TargetType="Border">
      <Setter Property="Background" Value="White"/>
      <Setter Property="BorderBrush" Value="#E1E7EF"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="14"/>
    </Style>
    <Style x:Key="MetricLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#6C788B"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>
    <Style x:Key="MetricValue" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#172033"/>
      <Setter Property="FontSize" Value="18"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Margin" Value="0,4,0,0"/>
    </Style>
    <Style x:Key="CenteredCellText" TargetType="TextBlock">
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
    </Style>
    <Style TargetType="DataGridColumnHeader">
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="#526075"/>
      <Setter Property="Padding" Value="10"/>
      <Setter Property="Background" Value="#F8FAFC"/>
      <Setter Property="BorderBrush" Value="#E6EBF2"/>
      <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>
    <Style TargetType="DataGridCell">
      <Setter Property="Padding" Value="8,5"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Background" Value="Transparent"/>
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="#E8F3FF"/>
          <Setter Property="Foreground" Value="#073B66"/>
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style TargetType="DataGridRow">
      <Setter Property="Background" Value="White"/>
      <Setter Property="Foreground" Value="#172033"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="BorderBrush" Value="#EDF1F5"/>
      <Setter Property="BorderThickness" Value="3,0,0,1"/>
      <Style.Triggers>
        <Trigger Property="AlternationIndex" Value="1">
          <Setter Property="Background" Value="#FBFCFE"/>
        </Trigger>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#F3F7FC"/>
        </Trigger>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="#EAF3FC"/>
          <Setter Property="BorderBrush" Value="#1672B8"/>
          <Setter Property="Foreground" Value="#073B66"/>
          <Setter Property="FontWeight" Value="SemiBold"/>
        </Trigger>
      </Style.Triggers>
    </Style>
  <Style TargetType="TabItem">
      <Setter Property="Foreground" Value="#526075"/>
      <Setter Property="Padding" Value="14,8"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
  </Style>
  <Style x:Key="PremiumTabItem" TargetType="TabItem">
    <Setter Property="Foreground" Value="#667085"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Margin" Value="2,0"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TabItem">
          <Border x:Name="HeaderBorder" Background="Transparent" BorderBrush="Transparent" BorderThickness="0,0,0,2" CornerRadius="7,7,0,0" Padding="14,9">
            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="HeaderBorder" Property="Background" Value="#EEF3F9"/></Trigger>
            <Trigger Property="IsSelected" Value="True"><Setter TargetName="HeaderBorder" Property="Background" Value="White"/><Setter TargetName="HeaderBorder" Property="BorderBrush" Value="#1672B8"/><Setter Property="Foreground" Value="#1261A6"/></Trigger>
            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.4"/></Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <Style x:Key="PremiumTabControl" TargetType="TabControl">
    <Setter Property="Background" Value="White"/>
    <Setter Property="BorderBrush" Value="#E1E7EF"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TabControl">
          <Border Background="#F7F9FC" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="8" ClipToBounds="True">
            <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
              <TabPanel Grid.Row="0" IsItemsHost="True" Margin="8,6,8,0" Background="Transparent"/>
              <Border Grid.Row="1" Background="{TemplateBinding Background}" BorderBrush="#E1E7EF" BorderThickness="0,1,0,0" CornerRadius="0,0,8,8">
                <ContentPresenter Content="{TemplateBinding SelectedContent}" ContentTemplate="{TemplateBinding SelectedContentTemplate}" ContentStringFormat="{TemplateBinding SelectedContentStringFormat}" Margin="0"/>
              </Border>
            </Grid>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
  <BooleanToVisibilityConverter x:Key="BooleanToVisibility"/>
  </Window.Resources>
  <DockPanel>
    <Border DockPanel.Dock="Top" Background="White" BorderBrush="#E1E7EF" BorderThickness="0,0,0,1" Padding="18,12,18,10">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel>
          <TextBlock Text="Messaging Server Manager" FontSize="22" Foreground="#142033" FontWeight="SemiBold"/>
          <TextBlock Text="{Binding ServerSummaryText}" Foreground="#6C788B" Margin="0,3,0,0"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,11,0,0">
          <Border Background="#F6F8FB" CornerRadius="7" Padding="3">
            <StackPanel Orientation="Horizontal">
              <Button Command="{Binding StartAllCommand}" ToolTip="Start all enabled servers">
                <StackPanel Orientation="Horizontal">
                  <icons:FluentIcon Icon="Play" IconSize="Size20" Foreground="#16803A"/>
                  <TextBlock Text="Start all" Margin="7,0,0,0"/>
                </StackPanel>
              </Button>
              <Button Command="{Binding StopAllCommand}" ToolTip="Stop all running servers">
                <StackPanel Orientation="Horizontal">
                  <icons:FluentIcon Icon="Stop" IconSize="Size20" Foreground="#C83C3C"/>
                  <TextBlock Text="Stop all" Margin="7,0,0,0"/>
                </StackPanel>
              </Button>
              <Button Command="{Binding RestartAllCommand}" ToolTip="Restart all running servers">
                <StackPanel Orientation="Horizontal">
                  <icons:FluentIcon Icon="ArrowSync" IconSize="Size20" Foreground="#266BB5"/>
                  <TextBlock Text="Restart all" Margin="7,0,0,0"/>
                </StackPanel>
              </Button>
            </StackPanel>
          </Border>
          <Border Background="#F6F8FB" CornerRadius="7" Padding="3" Margin="10,0,0,0">
            <StackPanel Orientation="Horizontal">
              <Button Style="{StaticResource PrimaryButton}" Command="{Binding AddServerCommand}">
                <StackPanel Orientation="Horizontal">
                  <icons:FluentIcon Icon="Add" IconSize="Size20"/>
                  <TextBlock Text="Add server" Margin="7,0,0,0"/>
                </StackPanel>
              </Button>
              <Button Style="{StaticResource IconButton}" Command="{Binding EditServerCommand}" ToolTip="Edit selected server">
                <icons:FluentIcon Icon="Edit" IconSize="Size20"/>
              </Button>
              <Button Style="{StaticResource IconButton}" Command="{Binding DeleteServerCommand}" ToolTip="Delete selected server">
                <icons:FluentIcon Icon="Delete" IconSize="Size20"/>
              </Button>
            </StackPanel>
          </Border>
          <Border Background="#F6F8FB" CornerRadius="7" Padding="3" Margin="10,0,0,0">
            <StackPanel Orientation="Horizontal">
              <Button Style="{StaticResource IconButton}" Command="{Binding ImportConfigurationCommand}" ToolTip="Load configuration">
                <icons:FluentIcon Icon="ArrowImport" IconSize="Size20"/>
              </Button>
              <Button Style="{StaticResource IconButton}" Command="{Binding ExportConfigurationCommand}" ToolTip="Save or export configuration">
                <icons:FluentIcon Icon="Save" IconSize="Size20"/>
              </Button>
              <Button Style="{StaticResource IconButton}" Command="{Binding RefreshCommand}" ToolTip="Refresh now">
                <icons:FluentIcon Icon="ArrowClockwise" IconSize="Size20"/>
              </Button>
              <Button Style="{StaticResource IconButton}" Command="{Binding OpenLogFolderCommand}" ToolTip="Open log folder">
                <icons:FluentIcon Icon="FolderOpen" IconSize="Size20"/>
              </Button>
              <Button Style="{StaticResource IconButton}" Command="{Binding SettingsCommand}" ToolTip="Settings">
                <icons:FluentIcon Icon="Settings" IconSize="Size20"/>
              </Button>
            </StackPanel>
          </Border>
        </StackPanel>
      </Grid>
    </Border>
    <StatusBar DockPanel.Dock="Bottom" Background="White">
      <TextBlock Text="{Binding Servers.Count,StringFormat=Monitoring: {0} servers}"/>
      <Separator/>
      <Ellipse Width="10" Height="10" Fill="#22C55E" Margin="12,0,4,0"/>
      <TextBlock Text="Monitor active"/>
      <Separator/>
      <TextBlock Text="{Binding LastUpdatedText}" HorizontalAlignment="Right"/>
    </StatusBar>
    <Grid Margin="14">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      <Border MinHeight="115" MaxHeight="330" Background="White" BorderBrush="#E1E7EF" BorderThickness="1" CornerRadius="8">
        <DataGrid ItemsSource="{Binding Servers}" SelectedItem="{Binding Selected}" AutoGenerateColumns="False" IsReadOnly="True" CanUserSortColumns="True" AlternationCount="2" HeadersVisibility="Column" GridLinesVisibility="None" BorderThickness="0" RowHeight="38" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
          <DataGrid.Columns>
            <DataGridTemplateColumn Header="Status" Width="60" SortMemberPath="Status">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center" ToolTip="{Binding StatusTooltip}">
                    <Ellipse Width="16" Height="16" Fill="{Binding StatusBrush}" Margin="5,0" VerticalAlignment="Center"/>
                  </StackPanel>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="260" MinWidth="155" ElementStyle="{StaticResource CenteredCellText}"/>
            <DataGridTextColumn Header="Type" Binding="{Binding TypeText}" Width="78" ElementStyle="{StaticResource CenteredCellText}"/>
            <DataGridTextColumn Header="Location" Binding="{Binding LocationText}" Width="70" ElementStyle="{StaticResource CenteredCellText}"/>
            <DataGridTextColumn Header="PID" Binding="{Binding Pid}" Width="58" ElementStyle="{StaticResource CenteredCellText}"/>
            <DataGridTemplateColumn Header="Port(s)" SortMemberPath="PrimaryPort" Width="98">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Ports}" ToolTip="{Binding PortsTooltip}" Style="{StaticResource CenteredCellText}"/>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTextColumn Header="Uptime" Binding="{Binding UptimeText}" SortMemberPath="Uptime" Width="78" ElementStyle="{StaticResource CenteredCellText}"/>
            <DataGridTemplateColumn Header="Connections" SortMemberPath="ConnectionCount" Width="92">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding ConnectionsText}" ToolTip="{Binding ActivityTooltip}" Style="{StaticResource CenteredCellText}"/>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTemplateColumn Header="Messages/s" SortMemberPath="MessageRateTotal" Width="126">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding MessageRateText}" ToolTip="{Binding ActivityTooltip}" Style="{StaticResource CenteredCellText}"/>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
      <DataGridTemplateColumn Header="Actions" Width="112" CanUserSort="False">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Button Style="{StaticResource CompactActionButton}" Visibility="{Binding CanStart,Converter={StaticResource BooleanToVisibility}}" ToolTip="Start server" AutomationProperties.Name="Start server" Command="{Binding DataContext.StartServerCommand,RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
                      <icons:FluentIcon Icon="Play" IconSize="Size20" Foreground="#16803A"/>
                    </Button>
            <Button Style="{StaticResource CompactActionButton}" Visibility="{Binding CanStop,Converter={StaticResource BooleanToVisibility}}" ToolTip="Stop server" AutomationProperties.Name="Stop server" Command="{Binding DataContext.StopServerCommand,RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
                      <icons:FluentIcon Icon="Stop" IconSize="Size20" Foreground="#C83C3C"/>
                    </Button>
            <Button Style="{StaticResource CompactActionButton}" Visibility="{Binding CanStop,Converter={StaticResource BooleanToVisibility}}" ToolTip="Restart server" AutomationProperties.Name="Restart server" Command="{Binding DataContext.RestartServerCommand,RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
                      <icons:FluentIcon Icon="ArrowSync" IconSize="Size20" Foreground="#266BB5"/>
                    </Button>
                    <Button Style="{StaticResource CompactActionButton}" ToolTip="{Binding RowActionTooltip}" AutomationProperties.Name="{Binding RowActionTooltip}" Command="{Binding DataContext.InspectServerCommand,RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}">
                      <icons:FluentIcon Icon="Pulse" IconSize="Size20" Foreground="#B66A12"/>
                    </Button>
                  </StackPanel>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>
      </Border>
      <UniformGrid Grid.Row="1" Columns="4" Margin="0,10,0,0" VerticalAlignment="Top">
        <Border Style="{StaticResource Card}" Margin="0,0,8,0">
          <StackPanel>
            <TextBlock Text="CONNECTIONS" Style="{StaticResource MetricLabel}"/>
            <TextBlock Text="{Binding Selected.ConnectionsText}" Style="{StaticResource MetricValue}"/>
          </StackPanel>
        </Border>
        <Border Style="{StaticResource Card}" Margin="0,0,8,0">
          <StackPanel>
            <TextBlock Text="MESSAGE RATE" Style="{StaticResource MetricLabel}"/>
            <TextBlock Text="{Binding Selected.MessageRateText}" Style="{StaticResource MetricValue}"/>
          </StackPanel>
        </Border>
        <Border Style="{StaticResource Card}" Margin="0,0,8,0">
          <StackPanel>
            <TextBlock Text="CPU" Style="{StaticResource MetricLabel}"/>
            <TextBlock Text="{Binding Selected.CpuText}" Style="{StaticResource MetricValue}"/>
          </StackPanel>
        </Border>
        <Border Style="{StaticResource Card}">
          <StackPanel>
            <TextBlock Text="MEMORY" Style="{StaticResource MetricLabel}"/>
            <TextBlock Text="{Binding Selected.MemoryText}" Style="{StaticResource MetricValue}"/>
          </StackPanel>
        </Border>
      </UniformGrid>
      <Border Grid.Row="2" Margin="0,10" Padding="12" MaxHeight="155" Background="White" BorderBrush="#E1E7EF" BorderThickness="1" CornerRadius="8">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
          </Grid.ColumnDefinitions>
          <StackPanel Margin="0,0,18,0">
            <TextBlock Text="{Binding Selected.Name,StringFormat=Server Details &#x2014; {0}}" Foreground="#075DB3" FontWeight="SemiBold" FontSize="15" Margin="0,0,0,8"/>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="115"/>
                <ColumnDefinition/>
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
              </Grid.RowDefinitions>
              <TextBlock Text="Executable / URL" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="1" Text="{Binding Selected.ExecutableDisplay}" ToolTip="{Binding Selected.ExecutableDisplay}" TextTrimming="CharacterEllipsis"/>
              <TextBlock Grid.Row="1" Text="Working directory" FontWeight="SemiBold"/>
              <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Selected.WorkingDirectoryDisplay}" ToolTip="{Binding Selected.Definition.WorkingDirectory}" TextTrimming="CharacterEllipsis" Foreground="#526075"/>
              <TextBlock Grid.Row="2" Text="Launch mode" FontWeight="SemiBold"/>
              <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Selected.LaunchModeDisplay}"/>
              <TextBlock Grid.Row="3" Text="Config file" FontWeight="SemiBold"/>
              <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Selected.ConfigFileDisplay}" ToolTip="{Binding Selected.Definition.ConfigFilePath}" TextTrimming="CharacterEllipsis" Foreground="#526075"/>
              <TextBlock Grid.Row="4" Text="Arguments" FontWeight="SemiBold"/>
              <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Selected.ArgumentsDisplay}" ToolTip="{Binding Selected.Definition.AdditionalArguments}" TextTrimming="CharacterEllipsis" Foreground="#526075"/>
            </Grid>
          </StackPanel>
          <StackPanel Grid.Column="1">
            <TextBlock Text="Process Statistics" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="75"/>
                <ColumnDefinition/>
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
              </Grid.RowDefinitions>
              <TextBlock Text="Status" FontWeight="SemiBold"/>
              <Border Grid.Column="1" BorderBrush="{Binding Selected.StatusBrush}" BorderThickness="1" CornerRadius="9" Padding="7,1" HorizontalAlignment="Left"><TextBlock Text="{Binding Selected.StatusText}" FontSize="11" FontWeight="SemiBold" Foreground="#344054"/></Border>
              <TextBlock Grid.Row="1" Text="PID" FontWeight="SemiBold"/>
              <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Selected.Pid}"/>
              <TextBlock Grid.Row="2" Text="Uptime" FontWeight="SemiBold"/>
              <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Selected.UptimeText}"/>
              <TextBlock Grid.Row="3" Text="CPU" FontWeight="SemiBold"/>
              <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Selected.CpuText}"/>
              <TextBlock Grid.Row="4" Text="Memory" FontWeight="SemiBold"/>
              <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Selected.MemoryText}"/>
            </Grid>
          </StackPanel>
          <StackPanel Grid.Column="2">
            <TextBlock Text="Health and Exit" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="95"/>
                <ColumnDefinition/>
              </Grid.ColumnDefinitions>
              <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
              </Grid.RowDefinitions>
              <TextBlock Text="Health" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="1" Text="{Binding Selected.Health}" TextWrapping="Wrap"/>
              <TextBlock Grid.Row="1" Text="Telemetry" FontWeight="SemiBold"/>
              <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Selected.TelemetryFreshnessText}" TextWrapping="Wrap"/>
              <TextBlock Grid.Row="2" Text="Last exit code" FontWeight="SemiBold"/>
              <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Selected.LastExitCode}"/>
              <TextBlock Grid.Row="3" Text="Last error" FontWeight="SemiBold"/>
              <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Selected.LastError}" Foreground="#B91C1C" TextWrapping="Wrap"/>
            </Grid>
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
              <Button Style="{StaticResource CompactActionButton}" Command="{Binding OpenLogCommand}" ToolTip="Open log file" AutomationProperties.Name="Open log file">
                <icons:FluentIcon Icon="Document" IconSize="Size20" Foreground="#B66A12"/>
              </Button>
              <Button Style="{StaticResource CompactActionButton}" Command="{Binding OpenLogFolderCommand}" ToolTip="Open log folder" AutomationProperties.Name="Open log folder">
                <icons:FluentIcon Icon="FolderOpen" IconSize="Size20" Foreground="#B66A12"/>
              </Button>
            </StackPanel>
          </StackPanel>
        </Grid>
      </Border>
      <TabControl Grid.Row="3" Style="{StaticResource PremiumTabControl}" ItemContainerStyle="{StaticResource PremiumTabItem}" SelectedIndex="{Binding SelectedDetailTabIndex}">
        <TabItem Header="Live Log">
          <DockPanel>
            <DockPanel DockPanel.Dock="Top" Margin="8,5">
              <TextBlock Text="{Binding Selected.LogFile,StringFormat=LIVE  •  {0}}" Foreground="#526075" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
              <Button Style="{StaticResource CompactActionButton}" Command="{Binding PauseLogCommand}" ToolTip="Pause live log" AutomationProperties.Name="Pause live log">
                <icons:FluentIcon Icon="Pause" IconSize="Size20" Foreground="#266BB5"/>
              </Button>
              <Button Style="{StaticResource CompactActionButton}" Command="{Binding ResumeLogCommand}" ToolTip="Resume live log" AutomationProperties.Name="Resume live log">
                <icons:FluentIcon Icon="Play" IconSize="Size20" Foreground="#16803A"/>
              </Button>
              <Button Style="{StaticResource CompactActionButton}" Command="{Binding ClearLogCommand}" ToolTip="Clear log view" AutomationProperties.Name="Clear log view">
                <icons:FluentIcon Icon="Delete" IconSize="Size20" Foreground="#C83C3C"/>
              </Button>
              </StackPanel>
            </DockPanel>
            <RichTextBox local:RichTextBoxLogBehavior.Text="{Binding LogText}" IsReadOnly="True" IsReadOnlyCaretVisible="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12.5" Background="#111827" Foreground="#E5E7EB" Padding="10" BorderThickness="0"/>
          </DockPanel>
        </TabItem>
        <TabItem Header="Server Metrics">
          <DockPanel>
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,2,3,2">
              <Button Style="{StaticResource CompactActionButton}" Command="{Binding RefreshSelectedTelemetryCommand}" ToolTip="Refresh telemetry" AutomationProperties.Name="Refresh telemetry">
                <icons:FluentIcon Icon="ArrowClockwise" IconSize="Size20" Foreground="#266BB5"/>
              </Button>
              <Button Style="{StaticResource CompactActionButton}" Command="{Binding CopyRawTelemetryCommand}" ToolTip="Copy raw telemetry" AutomationProperties.Name="Copy raw telemetry">
                <icons:FluentIcon Icon="Copy" IconSize="Size20" Foreground="#526075"/>
              </Button>
              <Button Style="{StaticResource CompactActionButton}" Command="{Binding OpenRawTelemetryCommand}" ToolTip="Open telemetry endpoint" AutomationProperties.Name="Open telemetry endpoint">
                <icons:FluentIcon Icon="Open" IconSize="Size20" Foreground="#B66A12"/>
              </Button>
            </StackPanel>
            <TabControl>
              <TabItem Header="Summary">
                <TextBox Margin="10" Text="{Binding SelectedRemoteMetrics,Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="13" Padding="8"/>
              </TabItem>
              <TabItem Header="Raw">
                <TextBox Margin="10" Text="{Binding SelectedRawTelemetry,Mode=OneWay}" IsReadOnly="True" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="12" Padding="8"/>
              </TabItem>
            </TabControl>
          </DockPanel>
        </TabItem>
        <TabItem Header="Process Details">
          <Grid Margin="15">
            <Grid.ColumnDefinitions>
              <ColumnDefinition/>
              <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="{Binding Selected.Started,StringFormat=Started: {0:G}}"/>
              <TextBlock Text="{Binding Selected.LastChecked,StringFormat=Last checked: {0:G}}"/>
              <TextBlock Text="{Binding Selected.LastExitTime,StringFormat=Last exit: {0:G}}"/>
              <TextBlock Text="{Binding Selected.LastExitCode,StringFormat=Exit code: {0}}"/>
              <TextBlock Text="{Binding Selected.RestartCount,StringFormat=Restart count: {0}}"/>
            </StackPanel>
            <StackPanel Grid.Column="1">
              <TextBlock Text="Effective arguments or monitoring endpoint" FontWeight="SemiBold"/>
              <TextBox Text="{Binding SelectedEffectiveArguments,Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" Margin="0,6" Padding="6"/>
            </StackPanel>
          </Grid>
        </TabItem>
        <TabItem Header="Configuration Summary">
          <TextBox Margin="15" Text="{Binding SelectedConfigurationSummary,Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" FontFamily="Consolas"/>
        </TabItem>
      </TabControl>
    </Grid>
  </DockPanel>
</Window>
